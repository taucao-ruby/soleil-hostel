{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "soleil-frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "frontend",
      "port": 5173
    },
    {
      "name": "soleil-backend",
      "runtimeExecutable": "php",
      "runtimeArgs": ["artisan", "serve", "--port", "8000"],
      "cwd": "backend",
      "port": 8000
    },
    {
      "name": "stitch-preview",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "-p", "5199", "stitch-preview"],
      "port": 5199
    }
  ]
}
