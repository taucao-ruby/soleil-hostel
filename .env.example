# Root Docker Compose environment template
# Copy this file to .env at the repository root when using docker compose.

# Application mode used by the backend container.
APP_ENV=local
APP_DEBUG=false

# PostgreSQL settings consumed by docker-compose.yml.
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=soleil_hostel
DB_USERNAME=soleil
DB_PASSWORD=secret

# Redis settings consumed by docker-compose.yml.
REDIS_HOST=redis
REDIS_PORT=6379
# Leave empty for local dev if you do not want Redis auth.
# Set a strong unique value in staging or production.
REDIS_PASSWORD=

# Frontend container API target.
API_URL=http://localhost:8000/api

# Cookie / Sanctum settings for local development.
SANCTUM_STATEFUL_DOMAINS=localhost:5173,127.0.0.1:5173
SESSION_DOMAIN=localhost

# Optional production overrides for docker-compose.prod.yml.
# FRONTEND_PORT=80
# DOMAIN=soleilhotel.com
