# Root Docker Compose environment template
# Copy this file to .env at the repository root when using docker compose.

# Application mode used by the backend container.
APP_ENV=local
APP_DEBUG=false

# PostgreSQL settings consumed by docker-compose.yml.
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=soleil_hostel
DB_USERNAME=soleil
DB_PASSWORD=secret

# Redis settings consumed by docker-compose.yml.
REDIS_HOST=redis
REDIS_PORT=6379
# REDIS_PASSWORD is required. docker-compose.yml uses ${REDIS_PASSWORD:?...} so
# `docker compose up` exits non-zero if it is unset or empty. The Laravel boot
# guard also refuses to start in non-local environments without it.
# Local dev: any non-empty value (the placeholder below is fine).
# Staging/production: must be a cryptographically random 32+ byte secret —
# generate with: openssl rand -base64 32
REDIS_PASSWORD=change_me_in_non_local_envs

# Frontend container API target.
API_URL=http://localhost:8000/api

# Cookie / Sanctum settings for local development.
SANCTUM_STATEFUL_DOMAINS=localhost:5173,127.0.0.1:5173
SESSION_DOMAIN=localhost
SESSION_SECURE_COOKIE=false

# Optional production overrides for docker-compose.prod.yml.
# FRONTEND_PORT=80
# DOMAIN=soleilhotel.com
