# Reverse proxy with automatic HTTPS (via Let's Encrypt)
# Usage: set DOMAIN env var before starting Caddy
#   DOMAIN=soleilhotel.com docker compose -f docker-compose.prod.yml --profile proxy up -d
#
# For local testing without TLS:
#   DOMAIN=localhost docker compose -f docker-compose.prod.yml --profile proxy up -d

{$DOMAIN:localhost} {
    # API requests → backend container
    handle /api/* {
        reverse_proxy backend:8080
    }

    # Frontend SPA → frontend container
    handle {
        reverse_proxy frontend:8080
    }

    # Security headers
    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
        Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
        Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self'; frame-ancestors 'none'"
        Permissions-Policy "camera=(), microphone=(), geolocation=()"
        X-XSS-Protection "1; mode=block"
        -Server
    }

    # Rate limiting: requires caddy-ext/ratelimit module (not in standard caddy:2-alpine image).
    # To enable, build a custom Caddy image with: xcaddy build --with github.com/mholt/caddy-ratelimit
    # Then add: rate_limit {remote.host} 100r/m

    # Logging
    log {
        output stdout
        format console
    }
}
