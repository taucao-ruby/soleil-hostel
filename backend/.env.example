APP_NAME=SoleilHostel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=Asia/Ho_Chi_Minh
BOOKING_BUSINESS_TIMEZONE=Asia/Ho_Chi_Minh

APP_LOCALE=vi
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# ========== DATABASE ==========
# For production: PostgreSQL (matches migrations with exclusion constraints, btree-gist, jsonb)
# For testing: PostgreSQL on the `soleil_test` database (configured in phpunit.xml).
#   The suite is PostgreSQL-only; start the DB with `docker compose up -d db` and
#   run `scripts/check-test-db.php` (GATE-0) to confirm readiness before testing.
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=soleil_hostel
DB_USERNAME=soleil
DB_PASSWORD=secret

# ========== CACHE & SESSION ==========
# For development: use database cache (no external dependency)
# For production with Redis: change to CACHE_STORE=redis
CACHE_DRIVER=database
CACHE_STORE=database
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=localhost

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# LOCAL DEV: use 'sync' so verification emails fire synchronously without a queue worker.
# PRODUCTION: change to 'redis' (or 'database') and run: php artisan queue:work
# WARNING: QUEUE_CONNECTION=redis without a running worker = notifications queued but NEVER delivered.
QUEUE_CONNECTION=sync

# ========== REDIS Configuration ==========
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
# REDIS_PASSWORD is required. AppServiceProvider::assertRedisAuthenticationConfiguration
# refuses to boot the application in non-local environments when it is empty,
# and docker-compose.yml uses ${REDIS_PASSWORD:?...} so the stack exits non-zero
# when it is unset. Local dev: any non-empty value works (the placeholder below
# is fine). Staging/production: cryptographically random 32+ byte secret —
# generate with: openssl rand -base64 32. Never commit real values.
REDIS_PASSWORD=change_me_in_non_local_envs
REDIS_PORT=6379
REDIS_PREFIX=soleil_
REDIS_CACHE_DB=1
REDIS_SESSION_DB=2
REDIS_RATE_LIMIT_DB=3
REDIS_QUEUE_DB=4

# WARNING: MAIL_MAILER=log means emails are only written to log files.
# In production, set to 'smtp', 'ses', 'postmark', 'resend', etc.
# Leaving as 'log' in production = users will NEVER receive emails.
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=your_email@example.com
MAIL_PASSWORD=your_email_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@soleil-hostel.local

# Email-OTP verification pepper (REQUIRED — no default, fails closed).
# Server-side HMAC key for verification-code hashes (F-82). Must be a
# high-entropy secret (e.g. `openssl rand -hex 32`), kept out of the DB and
# rotated like any credential. While unset, OTP issuance/verification
# throws — registration and resend flows will 500 by design.
OTP_PEPPER=

# Sanctum Configuration for API Authentication
SANCTUM_STATEFUL_DOMAINS=localhost:5173,127.0.0.1:5173
SESSION_DOMAIN=localhost
# Must be false for local HTTP development. Browsers refuse to store Secure
# cookies over HTTP, making $request->session() unavailable across requests on
# localhost.
SESSION_SECURE_COOKIE=false

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ========== STRIPE (Payment processing) ==========
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
CASHIER_CURRENCY=vnd

# ========== MOMO (Sandbox direct-payment path) ==========
# Additive MoMo AIO v2 sandbox path — see docs/backend/MOMO_SANDBOX_EXECUTION_PLAN.md.
# PUBLIC, MoMo-published sandbox test creds — shared across all sandbox users, NOT secrets.
# Swap for your own MoMo Business sandbox keys for a clean transId history. Never commit real keys.
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create
MOMO_PARTNER_CODE=MOMO
MOMO_ACCESS_KEY=F8BBA842ECF85
MOMO_SECRET_KEY=K951B6PE1waDMi640xX08PD3vg6EkVlz
MOMO_STORE_ID=SoleilHostel
MOMO_REQUEST_TYPE=captureWallet
# Server->server IPN + browser redirect targets. MoMo's IPN cannot reach localhost; for a live
# demo expose a tunnel (e.g. ngrok) and set the public URL. Not needed for the test suite
# (IPN is simulated). Align these paths with the T7 routes when they exist.
MOMO_IPN_URL=http://localhost:8000/api/v1/payments/momo/ipn
MOMO_REDIRECT_URL=http://localhost:5173/booking/momo/return
# Bounded HTTP timeouts (seconds) — mirror STRIPE_* posture; keep small so a MoMo call never
# hangs a worker near a booking/room lock.
MOMO_CONNECT_TIMEOUT=2
MOMO_READ_TIMEOUT=5

# ========== BOOKING (Pending-booking TTL) ==========
# Pending bookings block availability via Booking::ACTIVE_STATUSES. Without a
# TTL, an abandoned pending booking would hold the room indefinitely and
# silently corrupt availability reporting.
#
# ExpireStaleBookings runs every 5 minutes (routes/console.php) and transitions
# PENDING -> CANCELLED (cancellation_reason='expired') for rows older than this
# value, re-checking status under SELECT ... FOR UPDATE to avoid racing with a
# concurrent confirm().
#
# Setting BOOKING_PENDING_TTL_MINUTES=0 acts as an implicit kill switch: the
# job logs a warning and returns. Use this during incident response only, and
# drain the backlog manually (dispatch_sync(new ExpireStaleBookings)) before
# restoring the TTL. See docs/ROLLOUT_AND_KILL_SWITCH.md §Pending-Booking TTL
# Implicit Kill Switch for the full procedure.
BOOKING_PENDING_TTL_MINUTES=30
BOOKING_PENDING_EXPIRY_BATCH_SIZE=100

# ========== AI HARNESS ==========
# Master kill switch. Must be explicitly set to true to enable AI endpoints.
AI_HARNESS_ENABLED=false
AI_DEFAULT_PROVIDER=anthropic
AI_ANTHROPIC_MODEL=claude-sonnet-4-20250514
AI_OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

VITE_APP_NAME="${APP_NAME}"
