APP_NAME="Soleil Hostel"
APP_ENV=production
APP_KEY=base64:GENERATE_WITH_php_artisan_key_generate
APP_DEBUG=false
APP_URL=https://yourdomain.com
APP_TIMEZONE=Asia/Ho_Chi_Minh

# ========== DATABASE (PostgreSQL 16 required) ==========
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=soleil_hostel
DB_USERNAME=soleil
DB_PASSWORD=

# ========== REDIS ==========
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_PREFIX=soleil_hostel_

REDIS_CACHE_DB=1
REDIS_SESSION_DB=2
REDIS_RATE_LIMIT_DB=3
REDIS_QUEUE_DB=4

# ========== CACHE / SESSION / QUEUE ==========
CACHE_DRIVER=redis
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
QUEUE_CONNECTION=redis

# ========== MAIL ==========
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@yourdomain.com
MAIL_FROM_NAME="Soleil Hostel"

# ========== SANCTUM ==========
SANCTUM_STATEFUL_DOMAINS=yourdomain.com

# ========== COOKIE ==========
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTP_ONLY=true
SESSION_COOKIE_SAME_SITE=lax

# ========== LOGGING ==========
LOG_CHANNEL=stack
LOG_LEVEL=warning

# ========== SENTRY (optional) ==========
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ========== BOOKING (Pending-booking TTL) ==========
# Production MUST keep BOOKING_PENDING_TTL_MINUTES > 0. A value of 0 disables
# the ExpireStaleBookings job (implicit kill switch) and abandoned pending
# bookings will block room availability indefinitely. Restore promptly after
# any incident-response pause and run the job once by hand to drain backlog.
#
# See docs/agents/ARCHITECTURE_FACTS.md §Pending TTL for the invariant and
# docs/OPERATIONAL_PLAYBOOK.md §Pending Booking Backlog for the runbook.
BOOKING_PENDING_TTL_MINUTES=30
BOOKING_PENDING_EXPIRY_BATCH_SIZE=100
