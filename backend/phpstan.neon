parameters:
  level: 5

  paths:
    - app/

  excludePaths:
    - tests/
    - vendor/

  # Don't error on ignore patterns that match nothing (safe for broad patterns)
  reportUnmatchedIgnoredErrors: false

  ignoreErrors:
    # Laravel Eloquent magic static methods (where, find, create, etc.)
    - '#Call to an undefined static method App\\Models\\#'
    # Laravel Facades used as plain classes (Log, Redis, Blade, Octane)
    - '#on an unknown class (Log|Redis|Blade|Octane)#'
    # Illuminate undefined methods (query builder, relations, collections)
    - '#Call to an undefined method Illuminate\\#'
    - '#Call to an undefined static method Illuminate\\#'
    - '#Access to an undefined property#'
    # Stripe SDK (optional dependency, not in composer.json)
    - '#Stripe\\\\#'
    # Symfony Response methods wrapped by Laravel
    - '#Call to an undefined method Symfony\\Component\\HttpFoundation\\Response::#'
    # App-level dynamic methods (traits, macros, resource helpers)
    - '#Call to an undefined method App\\Http\\#'

  typeAliases:
    ID: 'int|string'
    BookingRequest: 'App\Http\Requests\StoreBookingRequest'
