<?xml version="1.0"?>
<psalm
    errorLevel="1"
    resolveFromConfigFile="true"
    xmlns="https://getpsalm.org/schema/config"
>
    <projectFiles>
        <directory name="app" />
        <directory name="bootstrap" />
        <directory name="config" />
        <directory name="routes" />
        <ignoreFiles>
            <directory name="vendor" />
            <directory name="tests" />
        </ignoreFiles>
    </projectFiles>

    <!-- ========== STRICT MODE: Level 1 (Maximum strictness) ========== -->
    <!-- Suppresses only Laravel framework false positives that cannot be    -->
    <!-- resolved without psalm/plugin-laravel. All genuine code quality     -->
    <!-- checks remain at error level.                                       -->
    <issueHandlers>

        <!-- ========== Eloquent Magic (no plugin available) ========== -->
        <UndefinedMagicPropertyFetch errorLevel="suppress" />
        <UndefinedMagicPropertyAssignment errorLevel="suppress" />
        <UndefinedMagicMethod errorLevel="suppress" />
        <UndefinedThisPropertyFetch errorLevel="suppress" />
        <UndefinedThisPropertyAssignment errorLevel="suppress" />

        <!-- Facades, optional deps, framework-wrapped methods -->
        <UndefinedClass>
            <errorLevel type="suppress">
                <directory name="app" />
                <directory name="config" />
                <directory name="bootstrap" />
            </errorLevel>
        </UndefinedClass>
        <UndefinedMethod errorLevel="suppress" />
        <UndefinedPropertyFetch errorLevel="suppress" />

        <!-- Framework parent class properties / factory pattern -->
        <PropertyNotSetInConstructor errorLevel="suppress" />
        <MissingConstructor errorLevel="suppress" />

        <!-- Auth contracts (Authenticatable::$id, Factory::user()) -->
        <NoInterfaceProperties errorLevel="suppress" />
        <UndefinedInterfaceMethod errorLevel="suppress" />
        <PossiblyUndefinedMethod errorLevel="suppress" />

        <!-- Eloquent collection/HasFactory template types -->
        <InvalidTemplateParam errorLevel="suppress" />
        <MissingTemplateParam errorLevel="suppress" />

        <!-- Laravel response()->cookie() accepts more args via macro -->
        <TooManyArguments errorLevel="suppress" />

        <!-- ========== Mixed Types (cascade from framework return types) ========== -->
        <MixedAssignment errorLevel="suppress" />
        <MixedMethodCall errorLevel="suppress" />
        <MixedPropertyFetch errorLevel="suppress" />
        <MixedArgument errorLevel="suppress" />
        <MixedArrayAccess errorLevel="suppress" />
        <MixedArrayOffset errorLevel="suppress" />
        <MixedReturnStatement errorLevel="suppress" />
        <MixedOperand errorLevel="suppress" />
        <MixedArgumentTypeCoercion errorLevel="suppress" />
        <MixedArrayAssignment errorLevel="suppress" />

        <!-- ========== Laravel Conventions ========== -->
        <ClassMustBeFinal errorLevel="suppress" />
        <MissingClosureReturnType errorLevel="suppress" />
        <MissingClosureParamType errorLevel="suppress" />
        <MissingParamType errorLevel="suppress" />
        <MissingReturnType errorLevel="suppress" />
        <MissingPropertyType errorLevel="suppress" />
        <MissingOverrideAttribute errorLevel="suppress" />

        <!-- option() casts, int/float arithmetic, redundant safety casts -->
        <RiskyCast errorLevel="suppress" />
        <RiskyTruthyFalsyComparison errorLevel="suppress" />
        <PossiblyInvalidArgument errorLevel="suppress" />
        <PossiblyInvalidCast errorLevel="suppress" />
        <PossiblyInvalidPropertyFetch errorLevel="suppress" />
        <InvalidOperand errorLevel="suppress" />
        <RedundantCast errorLevel="suppress" />

        <!-- Defensive null checks on framework values -->
        <RedundantCondition errorLevel="suppress" />
        <RedundantConditionGivenDocblockType errorLevel="suppress" />
        <TypeDoesNotContainNull errorLevel="suppress" />
        <DocblockTypeContradiction errorLevel="suppress" />
        <PossiblyNullReference errorLevel="suppress" />
        <PossiblyNullArgument errorLevel="suppress" />

        <!-- Route::middleware() returns RouteRegistrar but Psalm infers array|RouteRegistrar -->
        <PossiblyInvalidMethodCall errorLevel="suppress" />

        <!-- Eloquent property array type variance -->
        <NonInvariantDocblockPropertyType errorLevel="suppress" />

        <!-- Laravel macro $this binding -->
        <InvalidScope errorLevel="suppress" />

        <!-- Model delete()/forceDelete() returns bool|null, preg_replace returns string|null -->
        <InvalidNullableReturnType errorLevel="suppress" />
        <NullableReturnStatement errorLevel="suppress" />

        <!-- JsonResource toArray() returns MergeValue entries at numeric keys -->
        <InvalidReturnType>
            <errorLevel type="suppress">
                <directory name="app/Http/Resources" />
            </errorLevel>
        </InvalidReturnType>
        <InvalidReturnStatement>
            <errorLevel type="suppress">
                <directory name="app/Http/Resources" />
            </errorLevel>
        </InvalidReturnStatement>

        <!-- ========== Strict Type Checking (keep!) ========== -->
        <MoreSpecificReturnType errorLevel="error" />
        <LessSpecificReturnStatement errorLevel="error" />
        <InvalidScalarArgument errorLevel="error" />
        <InvalidArgument errorLevel="error" />

        <!-- ========== Code Quality ========== -->
        <UnusedVariable errorLevel="info" />
        <UnusedMethod errorLevel="info" />
        <UnusedClass errorLevel="info" />
        <UnusedParam errorLevel="info" />
        <UnusedProperty errorLevel="info" />
        <PossiblyUnusedProperty errorLevel="info" />
        <PossiblyUnusedReturnValue errorLevel="info" />
        <UnusedDocblockParam errorLevel="info" />

        <!-- ========== Deprecated Code ========== -->
        <DeprecatedMethod errorLevel="info" />
        <DeprecatedClass errorLevel="info" />
        <DeprecatedProperty errorLevel="info" />
        <DeprecatedFunction errorLevel="info" />

        <!-- ========== Internal Access ========== -->
        <InternalClass errorLevel="info" />
        <InternalMethod errorLevel="info" />
        <InternalProperty errorLevel="info" />
    </issueHandlers>

    <!-- ========== TYPE MAPPING ========== -->
    <globals>
        <var name="config" type="array&lt;string, mixed&gt;" />
        <var name="env" type="string" />
    </globals>
</psalm>
