{
  "name": "soleil-hostel-monorepo",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "concurrently \"cd backend && php artisan serve --host=127.0.0.1 --port=8000\" \"cd frontend && pnpm run dev -- --host\"",
    "dev:docker": "docker compose up --build frontend",
    "dev:backend": "cd backend && php artisan serve --host=127.0.0.1 --port=8000",
    "dev:frontend": "cd frontend && npm run dev -- --host",
    "start:docker": "docker compose up --build",
    "prepare": "husky",
    "hooks:install": "husky",
    "hooks:run:precommit": "node tools/hooks/pre-commit.mjs",
    "hooks:run:commitmsg": "node tools/hooks/commit-msg.mjs",
    "hooks:run:prepush": "node tools/hooks/pre-push.mjs",
    "lint-staged": "lint-staged"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "minimatch": "^10.1.2"
  }
}
